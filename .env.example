# KajuPilot env template
#
# Pick the right full example:
#   Local Windows dev:  copy .env.local.example .env
#   Oracle production:  cp .env.production.example .env
#
# The complete production example is in .env.production.example.
# The complete local example is in .env.local.example.
#
# Minimal required keys are shown below so Docker Compose config can still be inspected.

COMPOSE_PROJECT_NAME=kajupilot
DEPLOY_TARGET=local

DB_PASSWORD=replace_me_with_a_strong_password
JWT_SECRET=replace_me_with_a_64_character_random_secret

ADMIN_SETUP_CODE=KAJU-2026
ADMIN_USER=parth
ADMIN_SECRET=replace_me_with_admin_app_password
ADMIN_PASS_HASH=replace_me_with_docker_compose_safe_caddy_hash

API_HOST=api.localhost
ADMIN_HOST=admin.localhost
ADMIN_API_URL=http://api:3000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
ALLOWED_ORIGINS=http://localhost:3001,http://admin.localhost

AI_PROVIDER=openai
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60
GROQ_API_KEY=replace_me
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INPUT_COST_PER_1M=0.11
GROQ_OUTPUT_COST_PER_1M=0.34
AI_MAX_TOKENS=700
AI_TEMPERATURE=0.2
AI_PARSE_RATE_LIMIT_PER_HOUR=20
