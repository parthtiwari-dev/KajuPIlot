# KajuPilot local development env
# Copy this file to .env on your Windows machine when developing locally.
# Do not use this file on Oracle production.

COMPOSE_PROJECT_NAME=kajupilot
DEPLOY_TARGET=local

# Local dev database/JWT values. These are not production secrets.
DB_PASSWORD=kaju_dev_password
JWT_SECRET=dev_jwt_secret_1234567890_abcdefghijklmnopqrstuvwxyz_2026

# Android setup/admin dev values.
ADMIN_SETUP_CODE=KAJU-2026
ADMIN_USER=parth
ADMIN_SECRET=dev_admin_secret

# Caddy basic-auth hash is only needed if you run make up-full locally.
# Run: make hash ADMIN_PASSWORD=your_password
ADMIN_PASS_HASH=replace_me_with_caddy_hash_password_output

# Local routing.
# make up exposes API/admin directly through docker-compose.dev.yml:
#   API:   http://localhost:3000/api/v1
#   Admin: http://localhost:3001
# make run uses adb reverse so the phone can call http://127.0.0.1:3000/api/v1.
API_HOST=:80
ADMIN_HOST=admin.localhost
ADMIN_API_URL=http://api:3000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
ALLOWED_ORIGINS=http://localhost:3001,http://admin.localhost

# AI provider switch. Use openai by default; change only AI_PROVIDER=groq to switch.
AI_PROVIDER=openai
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60
GROQ_API_KEY=replace_me
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INPUT_COST_PER_1M=0.11
GROQ_OUTPUT_COST_PER_1M=0.34
AI_MAX_TOKENS=700
AI_TEMPERATURE=0.2
AI_PARSE_RATE_LIMIT_PER_HOUR=20
