# KajuPilot Oracle production env
# Copy this file to .env on the Oracle server, then replace only the values marked replace_me.
# Do not commit the real .env file.

# Docker project name. Keep this as kajupilot so volumes/containers are named predictably.
COMPOSE_PROJECT_NAME=kajupilot

# Production means Docker Compose should run only docker-compose.yml, not the dev override.
DEPLOY_TARGET=production

# Database password used inside the private Docker network.
# Generate a strong value on Oracle with: openssl rand -hex 24
DB_PASSWORD=replace_me_with_a_strong_random_database_password

# JWT signing secret for mobile device tokens and admin tokens.
# Generate a strong value on Oracle with: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_64_character_random_secret

# Code entered once in the Android setup screen.
# You can keep KAJU-2026 or use your own private setup code.
ADMIN_SETUP_CODE=KAJU-2026

# Admin app login. This is the password used on the Next admin login screen.
# For simplicity, use the same plaintext password you used to generate ADMIN_PASS_HASH.
ADMIN_USER=parth
ADMIN_SECRET=replace_me_with_admin_app_password

# Caddy basic-auth hash for the first browser popup on the admin site.
# IMPORTANT: Docker Compose needs every $ escaped as $$.
# Correct shape: ADMIN_PASS_HASH=$$2a$$14$$...
# Generate on Oracle:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your_admin_password' | sed 's/\$/$$/g'
ADMIN_PASS_HASH=replace_me_with_docker_compose_safe_caddy_hash

# Public HTTPS hostnames. These are sslip.io names for Oracle IP 141.148.213.89.
# If the Oracle IP changes, update all three public URL lines and rebuild the APK.
API_HOST=api.141.148.213.89.sslip.io
ADMIN_HOST=admin.141.148.213.89.sslip.io
NEXT_PUBLIC_API_URL=https://api.141.148.213.89.sslip.io/api/v1
ALLOWED_ORIGINS=https://admin.141.148.213.89.sslip.io

# Internal admin-to-API URL inside Docker. Do not change this to the public URL.
ADMIN_API_URL=http://api:3000/api/v1

# AI provider switch. Use openai by default; change only AI_PROVIDER=groq to switch.
AI_PROVIDER=openai

# OpenAI config. Required when AI_PROVIDER=openai.
OPENAI_API_KEY=replace_me_with_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60

# Groq config. Required only when AI_PROVIDER=groq.
GROQ_API_KEY=replace_me_with_groq_key_or_leave_placeholder
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INPUT_COST_PER_1M=0.11
GROQ_OUTPUT_COST_PER_1M=0.34

# Parser controls.
AI_MAX_TOKENS=700
AI_TEMPERATURE=0.2
AI_PARSE_RATE_LIMIT_PER_HOUR=20
